# Google Gemini API Configuration
GOOGLE_GENERATIVE_AI_API_KEY=tu_gemini_api_key

# Arkiv Network Configuration (Braga Testnet)
# Clave privada de la wallet para firmar transacciones de creación de entidades
ARKIV_PRIVATE_KEY=tu_private_key_para_braga_testnet

# Supabase Local & Production Configuration
NEXT_PUBLIC_SUPABASE_URL=tu_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key

# PostgreSQL Connection Configuration (Supabase DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_db_password
POSTGRES_HOST=tu_db_host
POSTGRES_DATABASE=postgres
POSTGRES_URL=postgres://postgres.tu_project:tu_password@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
POSTGRES_PRISMA_URL=postgres://postgres.tu_project:tu_password@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres.tu_project:tu_password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
